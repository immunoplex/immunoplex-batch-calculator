# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=changeme
REDIS_DB=0

# API Authentication
API_KEY=changeme

# PostgreSQL (worker only)
DB_NAME=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSLMODE=disable

# API reverse proxy path (set when behind Traefik/nginx with path prefix)
# ROOT_PATH=/batch-api
