# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=devpassword
REDIS_DB=0

# API Authentication
# For local dev this defaults to "dev-key-immunoplex" if not set.
# For production, generate a strong random key.
API_KEY=dev-key-immunoplex

# PostgreSQL (worker connects to your host DB)
DB_NAME=local_madi_ispi
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=hardik
DB_PASSWORD=
DB_SSLMODE=disable

# Output
OUTPUT_DIR=/data/bayes
